{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/resolve",
      "destination": "/resolve.html"
    },
    {
      "source": "/distrato",
      "destination": "/distrato.html"
    },
    {
      "source": "/((?!api/|resolve|distrato).*)",
      "destination": "/index.html"
    }
  ]
}